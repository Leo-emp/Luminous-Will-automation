# ============================================================
# GITIGNORE - Files that should NOT be pushed to GitHub
# ============================================================

# --- Environment variables (contains API keys - NEVER push this) ---
.env

# --- Python cache files ---
__pycache__/
*.py[cod]
*$py.class

# --- Temp files generated during video production ---
temp/

# --- Output videos (too large for GitHub) ---
output/
*.mp4

# --- Downloaded stock footage clips ---
clips/

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Queue data and tokens (sensitive, never push) ---
queue.json
.youtube_token.json
.tiktok_token.json
.instagram_token.json
.facebook_token.json
.used_topics.json
client_secrets.json

# --- IDE files ---
.vscode/
.idea/
*.swp
*.swo
